# OpenBlog Neo - Environment Variables Template
# Copy this file to .env and fill in your actual values
# DO NOT commit .env to version control (it's in .gitignore)

# ============================================================================
# REQUIRED: AI APIs
# ============================================================================

# Gemini API Key (required for all content generation)
# Get your API key from: https://aistudio.google.com/app/apikey
GEMINI_API_KEY="your-gemini-api-key-here"


# ============================================================================
# OPTIONAL: Legal Research (only needed for law firm content)
# ============================================================================

# Beck-Online Credentials (German legal database)
# URL: https://beck-online.beck.de/
# Provides: Court decisions, statutes, and authoritative legal commentary
# Required only when using --enable-legal-research WITHOUT --use-mock-legal-data
# Leave empty to use mock legal data for development
BECK_USERNAME=""
BECK_PASSWORD=""


# ============================================================================
# OPTIONAL: Google Drive (for webinar processing)
# ============================================================================

# Path to Google Cloud service account JSON credentials
# Required for webinar transcription from Google Drive
# Setup: https://console.cloud.google.com → IAM → Service Accounts
GOOGLE_DRIVE_CREDENTIALS="credentials/service_account.json"

# Google Drive folder ID containing webinar recordings
# Get from the folder URL: https://drive.google.com/drive/folders/<FOLDER_ID>
GOOGLE_DRIVE_WEBINAR_FOLDER=""

# Database path for persistent storage (default: data/openblog.db)
# OPENBLOG_DB_PATH="data/openblog.db"


# ============================================================================
# OPTIONAL: API Server Configuration
# ============================================================================

# Port for FastAPI server (default: 8000)
# Uncomment to override default
# PORT=8000

# Host for FastAPI server (default: 0.0.0.0)
# Uncomment to override default
# HOST=0.0.0.0


# ============================================================================
# OPTIONAL: Advanced Configuration
# ============================================================================

# Log level (default: INFO)
# Options: DEBUG, INFO, WARNING, ERROR, CRITICAL
# LOG_LEVEL=INFO

# Maximum concurrent articles in pipeline (default: unlimited)
# Uncomment to limit parallelism
# MAX_PARALLEL_ARTICLES=5
